<Window x:Class="EDNAClient.Skills.StatusPill.HudWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        Width="{StaticResource PillWidth}"
        Height="{StaticResource PillHeight}"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Title="EDNA">

    <Border Background="{StaticResource PillBackground}"
            CornerRadius="{StaticResource PillCorner}">
        <Ellipse Width="{StaticResource IndicatorSize}"
                 Height="{StaticResource IndicatorSize}"
                 Fill="{Binding IndicatorBrush}"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"/>
    </Border>

</Window>
