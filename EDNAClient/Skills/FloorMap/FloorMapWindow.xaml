<Window x:Class="EDNAClient.Skills.FloorMap.FloorMapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EDNA Floor Map"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResizeWithGrip"
        Width="640" Height="480"
        MinWidth="320" MinHeight="240"
        Background="#1A1A1A"
        ShowInTaskbar="True">

    <DockPanel>

        <!-- Toolbar: Refresh button + status label -->
        <ToolBar DockPanel.Dock="Top" Background="#2A2A2A" Foreground="#CCCCCC">
            <Button x:Name="RefreshButton"
                    Content="Refresh"
                    Click="OnRefreshClicked"
                    Padding="8,2"
                    Margin="2"/>
            <Separator/>
            <TextBlock x:Name="StatusLabel"
                       Text="{Binding StatusText}"
                       VerticalAlignment="Center"
                       Margin="4,0"
                       Foreground="#CCCCCC"/>
        </ToolBar>

        <!-- Map area: scroll over the rendered bitmap -->
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="#0A0A0A">
            <Image x:Name="MapImage"
                   Source="{Binding MapImage}"
                   Stretch="None"
                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"/>
        </ScrollViewer>

    </DockPanel>

</Window>
