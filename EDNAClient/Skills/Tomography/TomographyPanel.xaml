<UserControl x:Class="EDNAClient.Skills.Tomography.TomographyPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1A1A">

    <DockPanel>

        <ToolBar DockPanel.Dock="Top" Background="#2A2A2A" Foreground="#CCCCCC">
            <TextBlock Text="{Binding StatusText}"
                       VerticalAlignment="Center"
                       Margin="4,0"
                       Foreground="#CCCCCC"/>
        </ToolBar>

        <Grid Background="#050810">
        <Viewport3D x:Name="Viewport"
                    ClipToBounds="True">

            <Viewport3D.Camera>
                <PerspectiveCamera x:Name="Camera"
                                   Position="0,0,80"
                                   LookDirection="0,0,-1"
                                   UpDirection="0,1,0"
                                   FieldOfView="45"
                                   NearPlaneDistance="0.5"
                                   FarPlaneDistance="5000"/>
            </Viewport3D.Camera>

            <ModelVisual3D>
                <ModelVisual3D.Content>
                    <Model3DGroup>
                        <AmbientLight Color="#202830"/>
                        <DirectionalLight Color="#80B4D8" Direction="-0.4,-0.7,-0.6"/>
                        <DirectionalLight Color="#304060" Direction="0.6,0.4,0.7"/>
                    </Model3DGroup>
                </ModelVisual3D.Content>
            </ModelVisual3D>

            <ModelVisual3D x:Name="MeshHost"/>

        </Viewport3D>
        </Grid>

    </DockPanel>

</UserControl>
