<UserControl x:Class="EDNAClient.Skills.GalaxyMap.GalaxyMapPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True"
             MouseEnter="OnMouseEnter"
             MouseLeave="OnMouseLeave"
             MouseLeftButtonDown="OnMouseLeftButtonDown"
             MouseLeftButtonUp="OnMouseLeftButtonUp"
             MouseMove="OnMouseMove"
             MouseWheel="OnMouseWheel"
             PreviewKeyDown="OnKeyDown"
             PreviewKeyUp="OnKeyUp"
             Unloaded="OnUnloaded">
  <Grid Background="#05050F">
    <Viewport3D x:Name="Vp">
      <Viewport3D.Camera>
        <PerspectiveCamera x:Name="Cam"
                           FieldOfView="60"
                           UpDirection="0,1,0"
                           Position="115,80,20"
                           LookDirection="0,-0.342,0.940"/>
      </Viewport3D.Camera>
      <ModelVisual3D x:Name="StarField"/>
    </Viewport3D>

    <!-- star name labels projected from 3D to screen space -->
    <Canvas x:Name="LabelCanvas" IsHitTestVisible="False"/>

    <!-- status bar overlay -->
    <Border VerticalAlignment="Bottom"
            HorizontalAlignment="Stretch"
            Background="#AA000010"
            Padding="8,3">
      <TextBlock x:Name="StatusTb"
                 Foreground="#D4D4D4"
                 FontFamily="Consolas"
                 FontSize="12"/>
    </Border>

    <!-- movement hint overlay, top-right -->
    <TextBlock VerticalAlignment="Top"
               HorizontalAlignment="Right"
               Margin="0,4,8,0"
               Foreground="#606060"
               FontFamily="Consolas"
               FontSize="10"
               Text="WASD/QE move  drag rotate  scroll speed  click select"/>
  </Grid>
</UserControl>
