<Window x:Class="EDNAClient.Skills.ThreatRadar.ThreatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Title="EDNA Threat">

    <!--
        Fixed 200×200 coordinate space; the Viewbox scales it to the window's
        actual size (set at runtime to 1/3 of the game window height).

        Arc geometry: center (100,100), radius 80, each arc spans 80° with 10°
        gaps at the cardinal points.

          N arc: 230° → 310°  (top,    player-forward direction)
          E arc: 320° →  40°  (right)
          S arc:  50° → 130°  (bottom, behind player)
          W arc: 140° → 220°  (left)

        Angles use WPF screen convention: 0° = right (+X), 90° = down (+Y),
        increasing clockwise.
    -->
    <Viewbox Stretch="Uniform">
        <Canvas Width="200" Height="200">

            <!-- N (ahead) -->
            <Path x:Name="NorthArc"
                  Stroke="{StaticResource ThreatAmber}"
                  StrokeThickness="10"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  Fill="Transparent"
                  Opacity="0"
                  Data="M 48.6,38.7 A 80,80 0 0 1 151.4,38.7"/>

            <!-- E (right) -->
            <Path x:Name="EastArc"
                  Stroke="{StaticResource ThreatAmber}"
                  StrokeThickness="10"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  Fill="Transparent"
                  Opacity="0"
                  Data="M 161.3,48.6 A 80,80 0 0 1 161.3,151.4"/>

            <!-- S (behind) -->
            <Path x:Name="SouthArc"
                  Stroke="{StaticResource ThreatAmber}"
                  StrokeThickness="10"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  Fill="Transparent"
                  Opacity="0"
                  Data="M 151.4,161.3 A 80,80 0 0 1 48.6,161.3"/>

            <!-- W (left) -->
            <Path x:Name="WestArc"
                  Stroke="{StaticResource ThreatAmber}"
                  StrokeThickness="10"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  Fill="Transparent"
                  Opacity="0"
                  Data="M 38.7,151.4 A 80,80 0 0 1 38.7,48.6"/>

        </Canvas>
    </Viewbox>

</Window>
