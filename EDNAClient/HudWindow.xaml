<Window x:Class="EDNAClient.HudWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        Width="360" Height="Auto"
        Left="20" Top="20"
        ResizeMode="NoResize"
        Title="EDNA">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menubar / drag handle -->
        <Border Grid.Row="0"
                Background="#DD111111"
                CornerRadius="8,8,0,0"
                MouseLeftButtonDown="MenuBar_MouseLeftButtonDown">
            <DockPanel Margin="10,4">
                <TextBlock Text="EDNA"
                           DockPanel.Dock="Left"
                           Foreground="#FF00FF88"
                           FontSize="10" FontWeight="Bold"
                           FontFamily="Consolas"
                           VerticalAlignment="Center"/>
                <Menu DockPanel.Dock="Right"
                      Background="Transparent"
                      VerticalAlignment="Center">
                    <MenuItem Foreground="#FFAAAAAA" FontFamily="Consolas" FontSize="12"
                              Header="☰" Padding="4,0">
                        <MenuItem.Resources>
                            <Style TargetType="MenuItem">
                                <Setter Property="Background" Value="#FF1A1A1A"/>
                                <Setter Property="Foreground" Value="#FFCCCCCC"/>
                                <Setter Property="FontFamily" Value="Consolas"/>
                            </Style>
                        </MenuItem.Resources>
                        <MenuItem Header="Exit" Click="Exit_Click"/>
                    </MenuItem>
                </Menu>
            </DockPanel>
        </Border>

        <!-- Status content -->
        <Border Grid.Row="1"
                Background="#66000000"
                Padding="12,8"
                CornerRadius="0,0,8,8">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                    <Ellipse Width="7" Height="7"
                             Fill="{Binding BrokerStatusColor}"
                             VerticalAlignment="Center"
                             Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding BrokerStatus}"
                               Foreground="#FFAAAAAA"
                               FontSize="11"
                               FontFamily="Consolas"/>
                </StackPanel>
                <TextBlock Text="{Binding GameStatus}"
                           Foreground="White"
                           FontSize="13"
                           FontFamily="Consolas"
                           Margin="13,0,0,0"/>
                <TextBlock Text="{Binding StatusDetail}"
                           Foreground="#FFFF6666"
                           FontSize="10"
                           FontFamily="Consolas"
                           Margin="0,4,0,0"
                           Visibility="{Binding StatusDetailVisibility}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
